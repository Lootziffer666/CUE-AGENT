{
  "name": "cue-agent",
  "version": "1.3.0",
  "description": "CUE-AGENT - QA- & Verifikations-Agent für Web-/Android-UIs (Playwright + Vision): Bughunting, pixelgenaue Design-Checks, Severity-Scoring, autonome Test→Fix→Retest-Iteration und Release-Readiness. Promo-/Tutorial-/Showcase-Videos erst nach bestandener QA.",
  "main": "bin/cue.js",
  "bin": {
    "cue": "bin/cue.js"
  },
  "files": [
    "bin/",
    "src/",
    "examples/",
    "scripts/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node qa-agent.js",
    "test": "node --test",
    "cue": "node bin/cue.js",
    "qa": "node bin/cue.js qa",
    "doctor": "node bin/cue.js doctor",
    "postinstall": "node bin/postinstall.js || true",
    "install-browsers": "npx playwright install chromium"
  },
  "keywords": [
    "qa",
    "testing",
    "bughunting",
    "design-qa",
    "visual-regression",
    "design-baseline",
    "release-readiness",
    "severity-scoring",
    "autonomous-agent",
    "accessibility",
    "playwright",
    "anthropic",
    "claude",
    "vision",
    "video",
    "promo-video",
    "tutorial",
    "automation",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lootziffer666/CUE-AGENT.git"
  },
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "dotenv": "^16.4.7",
    "playwright": "^1.52.0"
  },
  "optionalDependencies": {
    "kokoro-js": "^1.2.1"
  }
}
