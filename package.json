{
  "name": "cue-agent",
  "version": "1.2.0",
  "description": "CUE-AGENT - QA-Bughunting & ultimativer Videoersteller (Playwright + Anthropic Claude Vision). QA-first Workflow, danach Promo-/Showcase-/Tutorial-Videos.",
  "main": "bin/cue.js",
  "bin": {
    "cue": "bin/cue.js"
  },
  "files": [
    "bin/",
    "src/",
    "examples/",
    "scripts/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node qa-agent.js",
    "cue": "node bin/cue.js",
    "qa": "node bin/cue.js qa",
    "doctor": "node bin/cue.js doctor",
    "postinstall": "node bin/postinstall.js || true",
    "install-browsers": "npx playwright install chromium"
  },
  "keywords": [
    "qa",
    "testing",
    "bughunting",
    "playwright",
    "anthropic",
    "claude",
    "vision",
    "video",
    "promo-video",
    "tutorial",
    "automation",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lootziffer666/CUE-AGENT.git"
  },
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "dotenv": "^16.4.7",
    "playwright": "^1.52.0"
  }
}
