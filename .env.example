# ============================================================================
# LLM-Provider (für QA-Analyse; die Video-Pipeline braucht KEIN LLM)
# ============================================================================
# Provider: anthropic (Default) | openai (OpenAI-kompatibel / LiteLLM / ANVIL-BELLOWS)
CUE_LLM_PROVIDER=anthropic

# -- Variante A: Anthropic (Default) --
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# -- Variante B: OpenAI-kompatibler Proxy (BYOK), z. B. dein ANVIL-BELLOWS --
#   CUE_LLM_PROVIDER=openai
#   CUE_LLM_BASE_URL=http://localhost:4000     # LiteLLM/ANVIL-BELLOWS Endpoint
#   CUE_LLM_MODEL=gpt-4o                         # Alias laut deiner config.yaml
#   CUE_LLM_API_KEY=sk-anvil-safe-key            # = LITELLM_MASTER_KEY (falls gesetzt)
# Hinweis: QA braucht ein bildfähiges Modell. gpt-4o -> Gemini 1.5 Pro kann Bilder.
CUE_LLM_BASE_URL=
CUE_LLM_MODEL=
CUE_LLM_API_KEY=

# Standard-Ziel-URL (optional, kann auch als CLI-Argument uebergeben werden)
TARGET_URL=https://example.com

# Sprache der Ausgaben: de | en (optional, Default: de)
CUE_LANG=de

# --- Optional, fuer die Video-Pipeline ---

# ElevenLabs API Key (optional) - hochwertige Text-to-Speech-Stimmen
ELEVENLABS_API_KEY=

# Freesound API Key (optional) - Suche nach Creative-Commons-Musik
FREESOUND_API_KEY=
